# ─── OpenAI ───────────────────────────────────────────────
# https://platform.openai.com/api-keys 에서 발급
OPENAI_API_KEY=YOUR_OPENAI_API_KEY

# ─── Flask 보안 키 ─────────────────────────────────────────
# 랜덤 문자열 (로그인 세션 암호화). 실제 배포 시 반드시 변경하세요.
# python -c "import secrets; print(secrets.token_hex(32))" 로 생성
SECRET_KEY=change-me-to-a-random-secret

# ─── PDF 경로 (선택) ──────────────────────────────────────
# 기본값: 앱 폴더 내 '건축기사 구조_ocr.pdf'
# Railway/서버 배포 시 볼륨 마운트 경로를 지정하세요.
# PDF_PATH=/data/건축기사 구조_ocr.pdf

# ─── DB 경로 (선택) ───────────────────────────────────────
# 기본값: 앱 폴더 내 users.db
# Railway Volume 마운트 후 지정하세요.
# DB_PATH=/data/users.db
